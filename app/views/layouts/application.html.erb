<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Badminton League</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green:      #2e7d32;
        --green-lt:   #43a047;
        --green-bg:   #e8f5e9;
        --red:        #c62828;
        --red-bg:     #ffebee;
        --gray-100:   #f5f5f5;
        --gray-200:   #eeeeee;
        --gray-400:   #bdbdbd;
        --gray-700:   #616161;
        --gray-900:   #212121;
        --white:      #ffffff;
        --radius:     6px;
        --shadow:     0 1px 4px rgba(0,0,0,.12);
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 15px;
        line-height: 1.5;
        color: var(--gray-900);
        background: var(--gray-100);
        min-height: 100vh;
      }

      /* ── Navigation ── */
      header {
        background: var(--green);
        color: var(--white);
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        height: 52px;
        box-shadow: 0 2px 6px rgba(0,0,0,.25);
      }
      header a { color: var(--white); text-decoration: none; }
      header .brand { font-weight: 700; font-size: 1.1rem; letter-spacing: .5px; }
      nav { display: flex; gap: 1.5rem; }
      nav a {
        font-size: .9rem;
        opacity: .85;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: opacity .15s, border-color .15s;
      }
      nav a:hover, nav a.active { opacity: 1; border-bottom-color: var(--white); }

      /* ── Page wrapper ── */
      main {
        max-width: 900px;
        margin: 2rem auto;
        padding: 0 1rem;
      }

      /* ── Flash messages ── */
      .flash {
        padding: .75rem 1rem;
        border-radius: var(--radius);
        margin-bottom: 1.25rem;
        font-size: .9rem;
        font-weight: 500;
      }
      .flash.notice { background: var(--green-bg); color: var(--green); border: 1px solid #a5d6a7; }
      .flash.alert  { background: var(--red-bg);   color: var(--red);   border: 1px solid #ef9a9a; }

      /* ── Cards ── */
      .card {
        background: var(--white);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .card h2 { font-size: 1.1rem; margin-bottom: 1rem; color: var(--gray-700); border-bottom: 1px solid var(--gray-200); padding-bottom: .5rem; }

      /* ── Buttons ── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        font-size: .9rem;
        font-weight: 500;
        text-decoration: none;
        transition: background .15s;
      }
      .btn-primary   { background: var(--green);    color: var(--white); }
      .btn-primary:hover { background: var(--green-lt); }
      .btn-danger    { background: var(--red);      color: var(--white); }
      .btn-danger:hover  { background: #e53935; }
      .btn-secondary { background: var(--gray-200); color: var(--gray-900); }
      .btn-secondary:hover { background: var(--gray-400); }

      /* ── Tables ── */
      table { width: 100%; border-collapse: collapse; font-size: .92rem; }
      thead th {
        text-align: left;
        padding: .6rem .8rem;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--gray-700);
        border-bottom: 2px solid var(--gray-200);
      }
      tbody tr { border-bottom: 1px solid var(--gray-200); }
      tbody tr:last-child { border-bottom: none; }
      tbody tr:hover { background: var(--gray-100); }
      td { padding: .65rem .8rem; }

      /* ── Forms ── */
      .form-group { margin-bottom: 1rem; }
      label { display: block; font-size: .85rem; font-weight: 600; margin-bottom: .3rem; color: var(--gray-700); }
      input[type="text"],
      input[type="date"],
      select {
        width: 100%;
        padding: .5rem .75rem;
        border: 1px solid var(--gray-400);
        border-radius: var(--radius);
        font-size: .95rem;
        color: var(--gray-900);
        background: var(--white);
        transition: border-color .15s;
      }
      input:focus, select:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 2px rgba(46,125,50,.15); }

      .error-messages {
        background: var(--red-bg);
        border: 1px solid #ef9a9a;
        color: var(--red);
        border-radius: var(--radius);
        padding: .75rem 1rem;
        margin-bottom: 1rem;
        font-size: .9rem;
      }
      .error-messages ul { padding-left: 1.2rem; margin-top: .3rem; }

      /* ── Misc ── */
      .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
      }
      .page-header h1 { font-size: 1.4rem; }

      .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: .8rem;
        font-weight: 600;
      }
      .badge-green { background: var(--green-bg); color: var(--green); }
      .badge-red   { background: var(--red-bg);   color: var(--red); }
      .badge-gray  { background: var(--gray-200);  color: var(--gray-700); }

      .rank-num {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--gray-700);
        min-width: 24px;
        display: inline-block;
        text-align: center;
      }
      .rank-1 { color: #f9a825; }
      .rank-2 { color: #9e9e9e; }
      .rank-3 { color: #8d6e63; }

      .text-muted { color: var(--gray-700); font-size: .9rem; }
      .mt-1 { margin-top: .5rem; }
      .empty-state { text-align: center; padding: 2rem; color: var(--gray-700); }
    </style>
  </head>

  <body>
    <header>
      <a href="/" class="brand">🏸 Badminton League</a>
      <nav>
        <a href="/players">Players</a>
        <a href="/matches">Matches</a>
      </nav>
    </header>

    <main>
      <% if notice.present? %>
        <div class="flash notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
